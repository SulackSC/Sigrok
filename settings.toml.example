# Copy to settings.toml and set Discord snowflakes for your server.
# See README for .secrets.toml (bot token, optional API keys).

[database]
url = "sqlite+aiosqlite:///data.db"
echo = false
pool_size = 10
max_overflow = 20
pool_recycle = 3600
pool_timeout = 30
backup_dir = "backups"
retention = 5

[bot]
prefix = "."
temp_dir = "."
cogs = ["misc", "presence", "backup", "voice_rec", "bluesky", "conditional_posts"]

[bot.owner]
id = 111111111111111111

[bot.intents]
guilds = true
messages = true
message_content = true
reactions = true
# Server Members Intent: must be enabled in the Developer Portal *and* set true here, or the bot
# fails to connect with PrivilegedIntentsRequired. Keep false unless you need TOML event_posts / presence.
members = false
voice_states = true

[bot.voice_record]
chunk_seconds = 30
directory = "voice_recordings"
announcement_file = ""
announcement_interval_seconds = 60

[[bot.whitelist]]
guild = 222222222222222222
channel = 333333333333333333
roles = []

[[bot.whitelist]]
guild = 444444444444444444
channel = 555555555555555555
roles = []

# Optional TOML: join/leave channel posts (guild must be whitelisted above).
# [[bot.event_posts]]
# guild = 222222222222222222
# channel = 333333333333333333
# on = "join"
# message = "Welcome {user_mention} to {guild}!"
# ignore_bots = true

# Optional TOML: fixed-interval channel posts.
# [[bot.timed_posts]]
# guild = 222222222222222222
# channel = 333333333333333333
# interval_minutes = 60
# message = "Hourly reminder."

[genai]
# Active backend (native llama-server on localhost:8081, model alias from llama-server.service).
model = "llamacpp/qwen3.6-35b-a3b"
base_url = "http://127.0.0.1:8081"
temperature = 1.05
repeat_penalty = 1.15
request_timeout = 180
# Rollback to prior native llama.cpp model:
# model = "llamacpp/qwen3.5-27b"
# base_url = "http://127.0.0.1:8081"
# Personality for Discord replies: resources/sigrok_personality_prompt.txt

[genai.tokens]
limit = 7000
overhead_max = 20
prompt_max = 100
output_max = 1024

[genai.history]
minutes = 1440
messages = 1000

[genai.question]
recent_messages = 25

[genai.web_search]
enabled = true
max_results = 5
timeout_seconds = 10

[genai.discord_streaming]
enabled = false
edit_interval_seconds = 2


[elo]
max_delta = 10
scale = 500

[social.bluesky]
enabled = true
identifier = ""
password = ""
max_chars = 300
poll_seconds = 30
state_file = ".bluesky_state.json"
thread_parent_height = 8

[social.x]
enabled = false
bearer_token = ""
max_chars = 280
